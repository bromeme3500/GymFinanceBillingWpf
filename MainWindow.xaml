<Window x:Class="GymFinanceBillingWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AeroGym - Gym Finance &amp; Billing" Height="800" Width="1280"
        WindowStartupLocation="CenterScreen" Background="{DynamicResource BgMain}">

    <Window.Resources>
        <Storyboard x:Key="FadeInTransition">
            <DoubleAnimation Storyboard.TargetName="ContentArea"
                             Storyboard.TargetProperty="Opacity"
                             From="0.0" To="1.0" Duration="0:0:0.3" />
            <ThicknessAnimation Storyboard.TargetName="ContentArea"
                                 Storyboard.TargetProperty="Margin"
                                 From="32,48,32,16" To="32,32,32,32" Duration="0:0:0.3">
                <ThicknessAnimation.EasingFunction>
                    <PowerEase Power="2" EasingMode="EaseOut" />
                </ThicknessAnimation.EasingFunction>
            </ThicknessAnimation>
        </Storyboard>
    </Window.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar Panel -->
        <Border Grid.Column="0" Background="{DynamicResource BgSidebar}" BorderBrush="{DynamicResource BorderMain}" BorderThickness="0,0,1,0">
            <Grid Margin="16,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Brand Header -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,40">
                    <Path Data="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z" 
                          Stroke="{StaticResource Secondary}" StrokeThickness="2.5" StrokeEndLineCap="Round" StrokeStartLineCap="Round" StrokeLineJoin="Round"
                          Width="24" Height="24" Stretch="Uniform" Margin="0,0,10,0"/>
                    <TextBlock Text="AeroGym" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
                </StackPanel>

                <!-- Sidebar Navigation Menu -->
                <StackPanel Grid.Row="1">
                    <Button x:Name="BtnDashboard" Content="Dashboard" Style="{StaticResource ButtonPremiumSecondary}" HorizontalContentAlignment="Left" Padding="12,10" BorderThickness="0" Background="Transparent" Click="NavigateDashboard" Margin="0,0,0,8" />
                    <Button x:Name="BtnMembers" Content="Gym Members" Style="{StaticResource ButtonPremiumSecondary}" HorizontalContentAlignment="Left" Padding="12,10" BorderThickness="0" Background="Transparent" Click="NavigateMembers" Margin="0,0,0,8" />
                    <Button x:Name="BtnSetup" Content="Setup Menu" Style="{StaticResource ButtonPremiumSecondary}" HorizontalContentAlignment="Left" Padding="12,10" BorderThickness="0" Background="Transparent" Click="NavigateSetup" Margin="0,0,0,8" />
                    <Button x:Name="BtnInvoices" Content="Invoices &amp; Bills" Style="{StaticResource ButtonPremiumSecondary}" HorizontalContentAlignment="Left" Padding="12,10" BorderThickness="0" Background="Transparent" Click="NavigateInvoices" Margin="0,0,0,8" />
                    <Button x:Name="BtnExpenses" Content="Expenses Logger" Style="{StaticResource ButtonPremiumSecondary}" HorizontalContentAlignment="Left" Padding="12,10" BorderThickness="0" Background="Transparent" Click="NavigateExpenses" Margin="0,0,0,8" />
                    <Button x:Name="BtnPayroll" Content="Payroll Manager" Style="{StaticResource ButtonPremiumSecondary}" HorizontalContentAlignment="Left" Padding="12,10" BorderThickness="0" Background="Transparent" Click="NavigatePayroll" Margin="0,0,0,8" />
                    <Button x:Name="BtnSettings" Content="Settings" Style="{StaticResource ButtonPremiumSecondary}" HorizontalContentAlignment="Left" Padding="12,10" BorderThickness="0" Background="Transparent" Click="NavigateSettings" Margin="0,0,0,8" />
                </StackPanel>

                <!-- User Panel -->
                <StackPanel Grid.Row="2">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Border Width="36" Height="36" CornerRadius="18" Background="{DynamicResource Primary}" Margin="0,0,10,0">
                            <TextBlock x:Name="TxtUserInitials" Text="?" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="TxtUserName" Text="Loading..." FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" FontSize="13" />
                            <TextBlock x:Name="TxtUserRole" Text="" Foreground="{DynamicResource TextSecondary}" FontSize="11" />
                        </StackPanel>
                    </StackPanel>
                    <Button Content="Logout" Style="{StaticResource ButtonPremiumDanger}" Click="BtnLogout_Click"
                            Height="32" FontSize="12" Padding="8,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Panel -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="72" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Top Header bar -->
            <Border Grid.Row="0" BorderBrush="{DynamicResource BorderMain}" BorderThickness="0,0,0,1" Padding="32,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="DATABASE STATUS" Foreground="{DynamicResource TextSecondary}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <Ellipse Width="8" Height="8" Fill="{StaticResource StatusPaid}" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="MYSQL SERVER ACTIVE" Foreground="{StaticResource StatusPaid}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="+ New Invoice" Style="{StaticResource ButtonPremium}" Click="CreateNewInvoiceClick" Height="36" Padding="16,0" Margin="0,0,16,0" />
                        <TextBlock x:Name="TxtDate" Text="Thursday, June 18, 2026" Foreground="{DynamicResource TextSecondary}" FontSize="13" VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Active View viewport -->
            <ContentControl Grid.Row="1" x:Name="ContentArea" Margin="32" />
        </Grid>
    </Grid>
</Window>


