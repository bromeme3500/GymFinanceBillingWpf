<Window x:Class="GymFinanceBillingWpf.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AeroGym — Login" Height="560" Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource BgMain}"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <Style x:Key="LoginTextBox" TargetType="TextBox">
            <Setter Property="FontFamily" Value="{StaticResource OutfitFont}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#12FFFFFF" />
            <Setter Property="BorderBrush" Value="#22FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="CaretBrush" Value="White" />
            <Setter Property="SelectionBrush" Value="{DynamicResource Primary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2,0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Primary}" />
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#6366F1" BlurRadius="10" ShadowDepth="0" Opacity="0.45" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LoginPasswordBox" TargetType="PasswordBox">
            <Setter Property="FontFamily" Value="{StaticResource OutfitFont}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#12FFFFFF" />
            <Setter Property="BorderBrush" Value="#22FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="CaretBrush" Value="White" />
            <Setter Property="SelectionBrush" Value="{DynamicResource Primary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2,0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Primary}" />
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#6366F1" BlurRadius="10" ShadowDepth="0" Opacity="0.45" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="16" Background="{DynamicResource BgMain}" BorderBrush="#1D2A46" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="0" Opacity="0.6" />
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="400" />
            </Grid.ColumnDefinitions>

            <!-- Left Decorative Panel -->
            <Border Grid.Column="0" CornerRadius="16,0,0,16" ClipToBounds="True">
                <Grid>
                    <!-- Dark gradient background -->
                    <Border>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#0B0F19" Offset="0" />
                                <GradientStop Color="#111827" Offset="0.5" />
                                <GradientStop Color="#0E1422" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Decorative glowing orb top-right -->
                    <Ellipse Width="280" Height="280" HorizontalAlignment="Right" VerticalAlignment="Top"
                             Margin="0,-80,-80,0" Opacity="0.12">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#6366F1" Offset="0" />
                                <GradientStop Color="Transparent" Offset="1" />
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <!-- Decorative glowing orb bottom-left -->
                    <Ellipse Width="200" Height="200" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                             Margin="-60,0,0,-60" Opacity="0.1">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#14B8A6" Offset="0" />
                                <GradientStop Color="Transparent" Offset="1" />
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <!-- Content -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="40,0">
                        <!-- Logo / Brand mark -->
                        <Border Width="64" Height="64" CornerRadius="16" HorizontalAlignment="Center" Margin="0,0,0,24">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#6366F1" Offset="0" />
                                    <GradientStop Color="#14B8A6" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Path Data="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"
                                  Stroke="White" StrokeThickness="2" Width="28" Height="28" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>

                        <TextBlock Text="AeroGym" FontSize="32" FontWeight="Bold" Foreground="#F3F4F6"
                                   HorizontalAlignment="Center" FontFamily="{StaticResource OutfitFont}" />
                        <TextBlock Text="Finance &amp; Billing Suite" FontSize="15" Foreground="#9CA3AF"
                                   HorizontalAlignment="Center" Margin="0,6,0,36" FontFamily="{StaticResource OutfitFont}" />

                        <StackPanel Margin="0,0,0,18">
                            <TextBlock FontSize="13" Foreground="#9CA3AF" Margin="0,0,0,4" FontFamily="{StaticResource OutfitFont}">
                                <Run Text="✦  " Foreground="{StaticResource Secondary}" />
                                <Run Text="Complete Member Management" />
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="#9CA3AF" Margin="0,0,0,4" FontFamily="{StaticResource OutfitFont}">
                                <Run Text="✦  " Foreground="{StaticResource Secondary}" />
                                <Run Text="Revenue Tracking &amp; Dashboard Analytics" />
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="#9CA3AF" Margin="0,0,0,4" FontFamily="{StaticResource OutfitFont}">
                                <Run Text="✦  " Foreground="{StaticResource Secondary}" />
                                <Run Text="Invoice Generation &amp; Expense Logging" />
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="#9CA3AF" FontFamily="{StaticResource OutfitFont}">
                                <Run Text="✦  " Foreground="{StaticResource Secondary}" />
                                <Run Text="Role-Based Access Control" />
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Right Login Form Panel -->
            <Border Grid.Column="1" Background="#0E1422" CornerRadius="0,16,16,0" Padding="44,48">
                <!-- Close button top-right -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Drag bar at top -->
                    <Border Grid.Row="0" Height="32" Background="Transparent" MouseLeftButtonDown="DragWindow"
                            Cursor="SizeAll" HorizontalAlignment="Stretch" Margin="-44,-48,-44,0">
                        <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center"
                                Margin="0,0,12,0" Background="Transparent" BorderThickness="0"
                                Foreground="#9CA3AF" FontSize="14" Cursor="Hand"
                                Click="CloseApp" />
                    </Border>

                    <!-- Login Form -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                        <TextBlock Text="Welcome Back" FontSize="26" FontWeight="Bold" Foreground="#F3F4F6"
                                   FontFamily="{StaticResource OutfitFont}" Margin="0,0,0,6" />
                        <TextBlock Text="Sign in to your account to continue." FontSize="13"
                                   Foreground="#9CA3AF"
                                   FontFamily="{StaticResource OutfitFont}" Margin="0,0,0,36" />

                        <!-- Username -->
                        <TextBlock Text="Username" Foreground="#9CA3AF"
                                   FontSize="12" FontWeight="SemiBold"
                                   FontFamily="{StaticResource OutfitFont}" Margin="0,0,0,8" />
                        <TextBox x:Name="TxtUsername" Style="{StaticResource LoginTextBox}"
                                 Height="46" Margin="0,0,0,20"
                                 KeyDown="InputKeyDown" />

                        <!-- Password -->
                        <TextBlock Text="Password" Foreground="#9CA3AF"
                                   FontSize="12" FontWeight="SemiBold"
                                   FontFamily="{StaticResource OutfitFont}" Margin="0,0,0,8" />
                        <PasswordBox x:Name="TxtPassword" Style="{StaticResource LoginPasswordBox}"
                                     Height="46" Margin="0,0,0,24"
                                     KeyDown="InputKeyDown" />

                        <!-- Error message -->
                        <Border x:Name="BorderError" Background="#1AEF4444" BorderBrush="#40EF4444"
                                BorderThickness="1" CornerRadius="8" Padding="12,10"
                                Visibility="Collapsed" Margin="0,0,0,20">
                            <TextBlock x:Name="TxtError" Text="Invalid username or password. Please try again."
                                       Foreground="#EF4444" FontSize="13"
                                       FontFamily="{StaticResource OutfitFont}" TextWrapping="Wrap" />
                        </Border>

                        <!-- Login Button -->
                        <Button x:Name="BtnLogin" Content="Sign In to AeroGym"
                                Height="48" FontSize="15" FontWeight="SemiBold"
                                FontFamily="{StaticResource OutfitFont}"
                                Foreground="#F3F4F6" Cursor="Hand"
                                Click="BtnLogin_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="btnBorder" CornerRadius="10" SnapsToDevicePixels="True">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#6366F1" Offset="0" />
                                                <GradientStop Color="#818CF8" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect Color="#6366F1" BlurRadius="16" ShadowDepth="0" Opacity="0.55" />
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="btnBorder" Property="Opacity" Value="0.85" />
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="btnBorder" Property="Opacity" Value="0.5" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Hint -->
                        <TextBlock Margin="0,24,0,0" FontSize="12"
                                   Foreground="#6B7280"
                                   FontFamily="{StaticResource OutfitFont}"
                                   TextAlignment="Center" TextWrapping="Wrap">
                            Default credentials:&#xA;
                            <Run FontWeight="SemiBold" Foreground="#9CA3AF">admin / admin</Run>
                            <Run Foreground="#6B7280">  or  </Run>
                            <Run FontWeight="SemiBold" Foreground="#9CA3AF">staff / staff</Run>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>


