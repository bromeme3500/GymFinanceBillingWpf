<Window x:Class="GymFinanceBillingWpf.ConnectionSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AeroGym — Database Connection" Height="560" Width="520"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{DynamicResource BgMain}" WindowStyle="None"
        AllowsTransparency="True">

    <Border CornerRadius="16" Background="{DynamicResource BgMain}"
            BorderBrush="{DynamicResource BorderMain}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="0" Opacity="0.6" />
        </Border.Effect>

        <Grid Margin="36,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Database Connection" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimary}" FontFamily="{StaticResource OutfitFont}" />
                        <TextBlock Text="Configure MySQL server settings for AeroGym."
                                   FontSize="13" Foreground="{DynamicResource TextSecondary}"
                                   FontFamily="{StaticResource OutfitFont}" Margin="0,4,0,0" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="✕" Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource TextSecondary}" FontSize="16" Cursor="Hand"
                            Click="CloseWindow" VerticalAlignment="Top" />
                </Grid>
            </StackPanel>

            <!-- Error Banner -->
            <Border Grid.Row="1" x:Name="BorderError" Background="#1AEF4444"
                    BorderBrush="#40EF4444" BorderThickness="1" CornerRadius="8"
                    Padding="14,10" Visibility="Collapsed" Margin="0,0,0,20">
                <TextBlock x:Name="TxtError" Foreground="#EF4444" FontSize="13"
                           FontFamily="{StaticResource OutfitFont}" TextWrapping="Wrap" />
            </Border>

            <!-- Form -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,0,12,0">
                    <!-- Server IP -->
                    <TextBlock Text="Server IP Address" Foreground="{DynamicResource TextSecondary}"
                               FontSize="12" FontWeight="SemiBold"
                               FontFamily="{StaticResource OutfitFont}" Margin="0,0,0,6" />
                    <TextBox x:Name="TxtServer" Style="{StaticResource TextBoxGlass}"
                             Height="40" Margin="0,0,0,4" />
                    <TextBlock Text="Use 'localhost' if MySQL is on this PC. Use the server's IP (e.g. 192.168.1.100) for a network server."
                               Foreground="{DynamicResource TextMuted}" FontSize="11"
                               FontFamily="{StaticResource OutfitFont}" TextWrapping="Wrap" Margin="0,0,0,16" />

                    <!-- Port -->
                    <TextBlock Text="Port" Foreground="{DynamicResource TextSecondary}"
                               FontSize="12" FontWeight="SemiBold"
                               FontFamily="{StaticResource OutfitFont}" Margin="0,0,0,6" />
                    <TextBox x:Name="TxtPort" Style="{StaticResource TextBoxGlass}"
                             Height="40" Margin="0,0,0,16" />

                    <!-- Database Name -->
                    <TextBlock Text="Database Name" Foreground="{DynamicResource TextSecondary}"
                               FontSize="12" FontWeight="SemiBold"
                               FontFamily="{StaticResource OutfitFont}" Margin="0,0,0,6" />
                    <TextBox x:Name="TxtDatabase" Style="{StaticResource TextBoxGlass}"
                             Height="40" Margin="0,0,0,16" />

                    <!-- Username -->
                    <TextBlock Text="MySQL Username" Foreground="{DynamicResource TextSecondary}"
                               FontSize="12" FontWeight="SemiBold"
                               FontFamily="{StaticResource OutfitFont}" Margin="0,0,0,6" />
                    <TextBox x:Name="TxtUser" Style="{StaticResource TextBoxGlass}"
                             Height="40" Margin="0,0,0,16" />

                    <!-- Password -->
                    <TextBlock Text="MySQL Password (leave blank if none)" Foreground="{DynamicResource TextSecondary}"
                               FontSize="12" FontWeight="SemiBold"
                               FontFamily="{StaticResource OutfitFont}" Margin="0,0,0,6" />
                    <PasswordBox x:Name="TxtPassword" Height="40" Margin="0,0,0,10"
                                 Background="#12FFFFFF" Foreground="{DynamicResource TextPrimary}"
                                 BorderBrush="{DynamicResource BorderMain}" BorderThickness="1"
                                 Padding="10,0" />
                </StackPanel>
            </ScrollViewer>

            <!-- Buttons -->
            <Grid Grid.Row="3" Margin="0,24,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" x:Name="BtnTest" Content="Test Connection"
                        Style="{StaticResource ButtonPremiumSecondary}"
                        Height="42" Click="BtnTest_Click" Margin="0,0,8,0" />
                <Button Grid.Column="1" x:Name="BtnSave" Content="Save &amp; Connect"
                        Style="{StaticResource ButtonPremium}"
                        Height="42" Click="BtnSave_Click" Margin="8,0,0,0" />
            </Grid>
        </Grid>
    </Border>
</Window>


